<%@page contentType="text/html" pageEncoding="UTF-8"%>
<%@page import="java.sql.*"%>
<%
String claimId = request.getParameter("claimId");
if (claimId == null) {
    out.println("<h3>No claim ID provided</h3>");
    return;
}
Connection conn=null; PreparedStatement ps=null; ResultSet rs=null;
try {
    Class.forName("org.apache.derby.jdbc.ClientDriver");
    conn=DriverManager.getConnection("jdbc:derby://localhost:1527/LostAndFound","app","app");
    ps=conn.prepareStatement("SELECT * FROM APP.CLAIM WHERE CLAIM_ID=?");
    ps.setString(1, claimId);
    rs=ps.executeQuery();
    if (rs.next()) {
%>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>E-Lost: Verify Claim</title>
<style>
body { font-family:'Segoe UI',Arial,sans-serif; background:#f4f6f9; margin:0; padding:0; }
header { background:indigo; color:white; padding:25px; text-align:center; }
header h1 { margin:0; font-size:28px; }
.container { max-width:900px; margin:40px auto; background:white; padding:30px; border-radius:12px; box-shadow:0px 6px 15px rgba(0,0,0,0.1); }
h2 { color:indigo; text-align:center; margin-bottom:30px; }
.section-title { color:indigo; margin-top:25px; margin-bottom:15px; font-size:20px; font-weight:bold; }
table { width:100%; border-collapse:collapse; margin-bottom:20px; }
td { border:1px solid #ddd; padding:12px; }
.label { width:30%; background:#f8f9fa; font-weight:bold; }
textarea { width:100%; height:100px; padding:10px; border:1px solid #ccc; border-radius:6px; resize:vertical; box-sizing:border-box; }
.decision-section { margin-top:20px; }
.decision-section label { margin-right:20px; font-weight:bold; }
.button-group { text-align:center; margin-top:30px; }
.btn { padding:10px 18px; border:none; border-radius:6px; cursor:pointer; margin:5px; font-size:14px; }
.approve-btn { background:#28a745; color:white; }
.reject-btn { background:#dc3545; color:white; }
.back-btn { background:#6c757d; color:white; }
.btn:hover { opacity:0.9; }
</style>
</head>
<body>
<header><h1>Verify Claim Request</h1></header>
<div class="container">
<h2>Claim Verification Details</h2>

<!-- Claim Information -->
<div class="section-title">Claim Information</div>
<table>
<tr><td class="label">Item ID</td><td><%=rs.getInt("ITEM_ID")%></td></tr>
<tr><td class="label">Item Name</td><td><%=rs.getString("ITEM_NAME")%></td></tr>
<tr><td class="label">Username</td><td><%=rs.getString("USERNAME")%></td></tr>
<tr><td class="label">Claim Date</td><td><%=rs.getString("CLAIM_DATE")%></td></tr>
<tr><td class="label">Proof Description</td><td><%=rs.getString("PROOF_DESCRIPTION")%></td></tr>
<tr><td class="label">Proof Image</td>
<td>
<%
String imgPath=rs.getString("PROOF_IMAGE");
if(imgPath!=null && !imgPath.isEmpty()){ %>
<img src="<%=imgPath%>" width="200" height="200" style="border-radius:8px;"/>
<% } else { %>No Image Provided<% } %>
</td></tr>
</table>


<div class="section-title">Verification Decision</div>
<form action="VerifyServlet" method="POST">

<input type="hidden" 
       name="claimId" 
       value="<%=claimId%>">


<div class="decision-section">

<label>
<input type="radio" 
       name="decision" 
       value="Approve" 
       required>
Approve
</label>


<label>
<input type="radio" 
       name="decision" 
       value="Reject">
Reject
</label>


</div>


<br>


<label><strong>Admin Remarks</strong></label>


<textarea name="remarks"
placeholder="Enter remarks here..."></textarea>



<div class="button-group">


<button class="btn approve-btn" 
        type="submit">

Submit Decision

</button>


<button class="btn back-btn" 
        type="button"
        onclick="location.href='admin_dashboard.jsp'">

Back

</button>


</div>


</form>
</div>
</body>
</html>
<%
    } else { out.println("<h3>No claim found</h3>"); }
} catch(Exception e) { out.println("<p style='color:red;'>Error: "+e.getMessage()+"</p>"); }
finally { if(rs!=null)rs.close(); if(ps!=null)ps.close(); if(conn!=null)conn.close(); }
%>
